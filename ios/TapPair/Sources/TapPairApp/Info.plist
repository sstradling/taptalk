<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>TapPair</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleName</key>
  <string>$(PRODUCT_NAME)</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSRequiresIPhoneOS</key>
  <true/>
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>TapPair uses Bluetooth to detect when your phone touches another player's phone.</string>
  <key>NSMotionUsageDescription</key>
  <string>TapPair uses motion to recognize the tap of two phones touching.</string>
  <key>NSLocalNetworkUsageDescription</key>
  <string>TapPair connects to the game server on your local network during dev builds.</string>
  <key>NSNearbyInteractionUsageDescription</key>
  <string>TapPair uses Nearby Interaction (UWB) to precisely confirm when phones are touching.</string>
  <key>UIBackgroundModes</key>
  <array>
    <string>bluetooth-central</string>
    <string>bluetooth-peripheral</string>
  </array>
  <key>UILaunchScreen</key>
  <dict/>
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>
  <key>UIApplicationSceneManifest</key>
  <dict>
    <key>UIApplicationSupportsMultipleScenes</key>
    <false/>
  </dict>
</dict>
</plist>
